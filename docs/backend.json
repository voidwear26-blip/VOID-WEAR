
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents an operator identity with logistical coordinates for module transmission.",
      "properties": {
        "uid": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "displayName": {
          "type": "string"
        },
        "mobileNumber": {
          "type": "string"
        },
        "addressLine1": {
          "type": "string"
        },
        "landmark": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "stateProvince": {
          "type": "string"
        },
        "postalCode": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": ["OPERATOR", "ADMIN", "COURIER"]
        },
        "isBlocked": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "uid",
        "email",
        "createdAt",
        "updatedAt"
      ]
    },
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents an individual product available for sale.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "basePrice": {
          "type": "number"
        },
        "imageUrls": {
          "type": "array",
          "items": { "type": "string" }
        },
        "category": {
          "type": "string"
        },
        "stockQuantity": {
          "type": "number"
        },
        "stockMatrix": {
          "type": "object"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Order": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Order",
      "type": "object",
      "description": "A confirmed transmission log with dual identifiers for logistics and verification.",
      "properties": {
        "id": { "type": "string" },
        "order_ID": { 
          "type": "string", 
          "description": "Logistical identifier for tracking (VOID-prefix)." 
        },
        "transition_ID": { 
          "type": "string", 
          "description": "Financial identifier for amount verification (Razorpay ID)." 
        },
        "userId": { "type": "string" },
        "totalAmount": { "type": "number" },
        "shippingStatus": { "type": "string" },
        "paymentStatus": { "type": "string" },
        "orderDate": { "type": "string", "format": "date-time" },
        "items": { "type": "array" }
      },
      "required": ["order_ID", "transition_ID", "userId", "totalAmount"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Operator dossiers."
        }
      },
      {
        "path": "/users/{userId}/orders/{orderId}",
        "definition": {
          "entityName": "Order",
          "schema": { "$ref": "#/backend/entities/Order" },
          "description": "Customer specific order history."
        }
      },
      {
        "path": "/products/{productId}",
        "definition": {
          "entityName": "Product",
          "schema": { "$ref": "#/backend/entities/Product" },
          "description": "Master catalogue."
        }
      }
    ]
  }
}
