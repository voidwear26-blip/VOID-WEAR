{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A technical apparel module in the VOID WEAR assemblage.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "basePrice": { "type": "number", "description": "Price in INR" },
        "imageUrls": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "color": { "type": "string" },
        "sizes": { "type": "array", "items": { "type": "string" } },
        "stockBySize": { 
          "type": "object",
          "description": "Stock quantity mapped to specific size keys (e.g., { 'S': 5, 'M': 7 })."
        },
        "slug": { "type": "string" },
        "details": { "type": "array", "items": { "type": "string" } },
        "stockQuantity": { "type": "number", "description": "Total sum of stockBySize units." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "basePrice", "category"]
    },
    "Review": {
      "title": "Review",
      "description": "Customer feedback for a technical module.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "orderId": { "type": "string" },
        "rating": { "type": "number", "minimum": 1, "maximum": 5 },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating"]
    },
    "Story": {
      "title": "Story",
      "description": "Dynamic updates regarding trends, offers, and arrivals.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["TREND", "OFFER", "NEW ARRIVAL"] },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "content"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google",
      "anonymous"
    ]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Global product catalog."
    },
    "/users/{userId}/orders/{orderId}": {
      "schema": "object",
      "description": "User transaction logs."
    },
    "/app_config/global": {
      "schema": "object",
      "description": "Global brand settings."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Global customer reviews."
    },
    "/stories/{storyId}": {
      "schema": "Story",
      "description": "Brand narrative updates."
    }
  }
}