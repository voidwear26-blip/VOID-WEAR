{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents an operator identity with logistical coordinates for module transmission.",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "The user's unique email address.",
          "format": "email"
        },
        "displayName": {
          "type": "string",
          "description": "The operator's public identifier."
        },
        "mobileNumber": {
          "type": "string",
          "description": "Primary mobile uplink for logistical coordination."
        },
        "addressLine1": {
          "type": "string",
          "description": "Primary physical coordinates."
        },
        "landmark": {
          "type": "string",
          "description": "Reference node for logistical proximity."
        },
        "city": {
          "type": "string",
          "description": "Urban district."
        },
        "stateProvince": {
          "type": "string",
          "description": "Regional territory."
        },
        "postalCode": {
          "type": "string",
          "description": "Logistical sector code."
        },
        "role": {
          "type": "string",
          "enum": ["OPERATOR", "ADMIN", "COURIER"]
        },
        "isBlocked": {
          "type": "boolean",
          "description": "Whether the uplink access has been severed."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "uid",
        "email",
        "createdAt",
        "updatedAt"
      ]
    },
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents an individual product available for sale in the 'VOID WEAR' app.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Product entity."
        },
        "name": {
          "type": "string",
          "description": "The name of the product."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the product, including features and materials."
        },
        "basePrice": {
          "type": "number",
          "description": "The current selling price of the product."
        },
        "imageUrls": {
          "type": "array",
          "description": "An array of URLs to product images.",
          "items": {
            "type": "string"
          }
        },
        "category": {
          "type": "string",
          "description": "The primary category of the product."
        },
        "stockQuantity": {
          "type": "number",
          "description": "Total available units."
        },
        "stockMatrix": {
          "type": "object",
          "description": "Multi-dimensional inventory state (Size > Color > Quantity)."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "basePrice",
        "imageUrls",
        "category",
        "createdAt",
        "updatedAt"
      ]
    },
    "Order": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Order",
      "type": "object",
      "description": "Represents a confirmed transmission log with logistical and financial identifiers.",
      "properties": {
        "id": {
          "type": "string"
        },
        "order_ID": {
          "type": "string",
          "description": "Logistical identifier for product tracking."
        },
        "transition_ID": {
          "type": "string",
          "description": "Financial identifier for amount verification."
        },
        "userId": {
          "type": "string"
        },
        "orderDate": {
          "type": "string",
          "format": "date-time"
        },
        "totalAmount": {
          "type": "number"
        },
        "shippingStatus": {
          "type": "string"
        },
        "paymentStatus": {
          "type": "string"
        }
      }
    },
    "WishlistItem": {
      "title": "WishlistItem",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "google"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores individual operator dossiers."
        }
      },
      {
        "path": "/users/{userId}/wishlist/{productId}",
        "definition": {
          "entityName": "WishlistItem",
          "schema": {
            "$ref": "#/backend/entities/WishlistItem"
          },
          "description": "Operator module stasis log."
        }
      },
      {
        "path": "/products/{productId}",
        "definition": {
          "entityName": "Product",
          "schema": {
            "$ref": "#/backend/entities/Product"
          },
          "description": "Master assemblage catalogue."
        }
      }
    ]
  }
}