rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VOID WEAR - Master Administrative Security Rules v3.7
     * Primary Administrator: voidwear26@gmail.com
     * Updated: Global recursive permission override for Master Admin.
     * Note: This version explicitly handles collectionGroup queries for Admin Dashboard.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * Master Admin Authorization.
     * Checks for the master email or admin role in the database.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() == "voidwear26@gmail.com" || 
        exists(/databases/$(database)/documents/app_roles/admin/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- MASTER OVERRIDE ---
    // Absolute authority for the Master Admin account.
    // Explicitly covers root-level queries and recursive matches.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- COLLECTION GROUP RULES ---
    // Required for the Admin Dashboard to list items across all users globally.
    match /{path=**}/orders/{orderId} {
      allow read, write: if isAdmin();
    }
    
    match /{path=**}/items/{itemId} {
      allow read, write: if isAdmin();
    }

    // --- STANDARD COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /app_config/{configId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
