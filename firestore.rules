rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VOID WEAR SECURITY RULES
     * 
     * CORE PHILOSOPHY:
     * This ruleset enforces a strict User-Ownership model. All user-specific data is 
     * hierarchically nested under the user's primary document to ensure authorization 
     * is tied directly to the document path.
     * 
     * DATA STRUCTURE:
     * - /users/{userId}: Private profile data.
     * - /users/{userId}/carts/...: Shopping carts owned by the user.
     * - /users/{userId}/orders/...: Purchase history owned by the user.
     * - /products/{productId}: Publicly available catalog data.
     * 
     * KEY SECURITY DECISIONS:
     * 1. Path-Based Authorization: We use the {userId} parameter in the path to grant 
     *    access, avoiding expensive get() calls and ensuring high performance.
     * 2. Denormalization for Integrity: We require that critical relational fields 
     *    (like userId or cartId) inside the document match the path parameters.
     * 3. Prototyping Flexibility: While authorization is strict, we do not enforce 
     *    non-relational data types (e.g., price being a number) to allow rapid iteration.
     * 4. Public Access: Products are globally readable by any visitor.
     */

    // --- Helper Functions ---

    /** Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks ownership and ensures the document exists for state-changing operations. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the User profile. Only the owner can read or write.
     * @path /users/{userId}
     * @allow (create) auth.uid 'user123' creates /users/user123 with id 'user123'.
     * @deny (get) auth.uid 'userABC' attempts to read /users/user123.
     * @principle Restricts access to a user's own data tree and validates path consistency.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for user-specific shopping carts.
       * @path /users/{userId}/carts/{cartId}
       * @allow (list) auth.uid 'user123' lists /users/user123/carts.
       * @deny (create) auth.uid 'user123' creates cart with userId 'otherUser'.
       * @principle Enforces path-based ownership for nested collections.
       */
      match /carts/{cartId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Rules for items within a specific cart.
         * @path /users/{userId}/carts/{cartId}/cartItems/{cartItemId}
         * @allow (update) auth.uid 'user123' updates quantity in their own cart item.
         * @deny (update) auth.uid 'user123' changes the cartId of an item.
         * @principle Inherited ownership through the document path.
         */
        match /cartItems/{cartItemId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.cartId == cartId;
          allow update: if isExistingOwner(userId) && request.resource.data.cartId == resource.data.cartId;
          allow delete: if isExistingOwner(userId);
        }
      }

      /**
       * @description Rules for user-specific orders.
       * @path /users/{userId}/orders/{orderId}
       * @allow (get) auth.uid 'user123' views their order receipt.
       * @deny (delete) auth.uid 'user123' attempts to delete their order history.
       * @principle Strict ownership for transactional records.
       */
      match /orders/{orderId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Rules for individual products within a confirmed order.
         * @path /users/{userId}/orders/{orderId}/orderItems/{orderItemId}
         * @allow (get) auth.uid 'user123' views items in their order.
         * @deny (create) auth.uid 'user123' creates item for someone else's order.
         * @principle Hierarchical access control for order details.
         */
        match /orderItems/{orderItemId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.orderId == orderId;
          allow update: if isExistingOwner(userId) && request.resource.data.orderId == resource.data.orderId;
          allow delete: if isExistingOwner(userId);
        }
      }
    }

    /**
     * @description Public product catalog. Readable by all, writable only by admins.
     * @path /products/{productId}
     * @allow (get) Unauthenticated visitor views a product.
     * @deny (create) Authenticated non-admin user attempts to add a product.
     * @principle Segregates public read-only data from private user data.
     */
    match /products/{productId} {
      allow get, list: if true;
      
      // CRITICAL: Cannot implement owner-only writes. The Product entity is missing an ownerId or authorId field.
      // Admin roles are not defined in the provided IR.
      allow create, update, delete: if false; // TODO: Add admin or owner validation once the schema/roles are defined.
    }
  }
}