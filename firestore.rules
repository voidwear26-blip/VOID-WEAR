rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VOID WEAR SECURITY RULES
     * MASTER AUTHORITY: voidwear26@gmail.com
     * VERSION: 12.8 - GLOBAL OVERRIDE ENABLED
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email.lower() == 'voidwear26@gmail.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Master Authority Override ---
    // Grants the primary administrator absolute authority over the entire database.
    // This recursive wildcard must be prioritized for collection group queries.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- Collection Specific Rules (For Non-Admin Operators) ---

    match /app_config/{configId} {
      allow read: if true;
    }

    match /stories/{storyId} {
      allow read: if true;
    }

    match /products/{productId} {
      allow read: if true;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /users/{userId} {
      // Allow any signed-in user to manage their own dossier
      allow get, create, update: if isOwner(userId) || isAdmin();
      
      match /carts/{cartId} {
        allow read, write: if isOwner(userId) || isAdmin();

        match /items/{itemId} {
          allow read, write: if isOwner(userId) || isAdmin();
        }
      }

      match /orders/{orderId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /wishlist/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    /**
     * @description Collection Group rules for Global Mission Audits.
     * Note: isAdmin() override above also covers these, but explicit matches help.
     */
    match /{path=**}/orders/{orderId} {
      allow read, write: if isAdmin() || isOwner(resource.data.userId);
    }

    match /{path=**}/items/{itemId} {
      allow read, write: if isAdmin() || isOwner(resource.data.userId);
    }
  }
}