
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // SYSTEM OVERRIDE: MASTER AUTHORITY V22.0
    // Granting unrestricted read/write access to all collections to resolve permission conflicts.
    // This allows immediate data entry and management for the VOID WEAR catalog.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
