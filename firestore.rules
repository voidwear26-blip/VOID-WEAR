rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VOID WEAR SECURITY RULES v26.0
     * MASTER AUTHORITY: voidwear26@gmail.com (A9vsqn10oddfmouKiKjWpTcFqZB2)
     * UNIVERSAL OVERRIDE FOR GLOBAL TRANSMISSION AUDITS
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'A9vsqn10oddfmouKiKjWpTcFqZB2' ||
        (request.auth.token.email != null && request.auth.token.email.lower() == 'voidwear26@gmail.com')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Universal Master Authority ---
    // Priority check for administrative identity to allow broad collection group queries.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- Collection Group Rule for Orders ---
    // Critical for the Command Center's global 'list' operations.
    match /{path=**}/orders/{orderId} {
      // Admin: Absolute oversight
      allow list, get: if isAdmin();
      
      // Operator: Restricted to their own dossier
      allow list, get: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // --- Standard Collection Access ---

    match /app_config/{configId} {
      allow read: if true;
    }

    match /stories/{storyId} {
      allow read: if true;
    }

    match /products/{productId} {
      allow read: if true;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid);
    }

    match /users/{userId} {
      allow get, list, create, update: if isOwner(userId) || isAdmin();
      
      match /carts/{cartId} {
        allow read, write: if isOwner(userId) || isAdmin();
        match /items/{itemId} {
          allow read, write: if isOwner(userId) || isAdmin();
        }
      }

      match /orders/{orderId} {
        allow list, get: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update, delete: if isAdmin();
      }

      match /wishlist/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
  }
}