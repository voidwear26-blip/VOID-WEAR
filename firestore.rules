
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VOID WEAR SECURITY RULES v22.0
     * MASTER AUTHORITY: voidwear26@gmail.com
     * BULLETPROOF UID-FIRST AUTHORIZATION
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'A9vsqn10oddfmouKiKjWpTcFqZB2' ||
        (request.auth.token.email != null && request.auth.token.email.lower() == 'voidwear26@gmail.com')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Universal Master Authority ---
    // Grants absolute authority to the Master Administrator for all documents.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- Explicit Collection Group Audit Rule ---
    // Required for the Revenue Dashboard and Transmission Archives.
    match /{path=**}/orders/{orderId} {
      allow list, read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // --- Standard Collection Access for Operators ---

    match /app_config/{configId} {
      allow read: if true;
    }

    match /stories/{storyId} {
      allow read: if true;
    }

    match /products/{productId} {
      allow read: if true;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid);
    }

    match /users/{userId} {
      // Granting full access to owners for dossier management
      allow get, list, create, update: if isOwner(userId) || isAdmin();
      
      match /carts/{cartId} {
        allow read, write: if isOwner(userId) || isAdmin();
        match /items/{itemId} {
          allow read, write: if isOwner(userId) || isAdmin();
        }
      }

      match /orders/{orderId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update, delete: if isAdmin();
      }

      match /wishlist/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
  }
}
