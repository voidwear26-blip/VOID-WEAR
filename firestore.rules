rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VOID WEAR SECURITY RULES
     * MASTER AUTHORITY: voidwear26@gmail.com
     * VERSION: 14.0 - ABSOLUTE UPLINK ACTIVE
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email.lower() == 'voidwear26@gmail.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Master Authority Override ---
    // Grants the primary administrator absolute authority over the entire database architecture.
    // Explicitly allowing all methods including 'list' for collection group queries.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- Collection Specific Rules (For Non-Admin Operators) ---

    match /app_config/{configId} {
      allow read: if true;
    }

    match /stories/{storyId} {
      allow read: if true;
    }

    match /products/{productId} {
      allow read: if true;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid);
    }

    match /users/{userId} {
      allow get, create, update: if isOwner(userId);
      
      match /carts/{cartId} {
        allow read, write: if isOwner(userId);
        match /items/{itemId} {
          allow read, write: if isOwner(userId);
        }
      }

      match /orders/{orderId} {
        allow read, write: if isOwner(userId);
      }

      match /wishlist/{productId} {
        allow read, write: if isOwner(userId);
      }
    }

    /**
     * @description Collection Group rules for Global Mission Audits.
     * Hardened to ensure Master and Owners can audit transmissions across the void.
     */
    match /{path=**}/orders/{orderId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }
  }
}
