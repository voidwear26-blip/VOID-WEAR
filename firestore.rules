rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VOID WEAR - Master Administrative Security Rules v6.0
     * Primary Administrator: voidwear26@gmail.com
     * Absolute Authority Override (Recursive Wildcard Support)
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "voidwear26@gmail.com"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- MASTER OVERRIDE ---
    // This rule is prioritized to allow the Master Admin absolute access to all paths,
    // including collectionGroup queries (e.g., /orders across all users).
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- STANDARD ENTITY RULES ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);

      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /app_config/{configId} {
      allow get, list: if true;
    }

    match /products/{productId} {
      allow get, list: if true;
    }
    
    // Deployment Comment: Synchronizing Master Authority v6.0 - Full Root Access
  }
}