rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VOID WEAR - Security Rules Architecture v1.9
     * Optimized for Master Administrative Command and Global Logistics.
     * Fixed: Root level list authorization for administrative entities.
     * Deployment Trigger: Root-level Administrative Email Authorization Sync.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Master Admin Authorization.
     * Checks for the hardcoded master email.
     */
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "voidwear26@gmail.com";
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- MASTER OVERRIDE ---
    // Universal access for the Master Administrator at the root level.
    // This allows collectionGroup queries and global list operations.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- COLLECTION RULES ---

    // Users & Profiles
    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isAdmin()) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId) || isAdmin();

      // Sub-collections inherit owner/admin access.
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Global App Configuration
    match /app_config/{configId} {
      allow get, list: if true; // Publicly readable for branding.
      allow write: if isAdmin();
    }

    // Product Catalog
    match /products/{productId} {
      allow get, list: if true; // Publicly readable.
      allow create, update, delete: if isAdmin();

      match /{allSubcollections=**} {
        allow get, list: if true;
        allow create, update, delete: if isAdmin();
      }
    }

    // System Roles (Read-only for identification)
    match /app_roles/admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if false; // Only manageable via Firebase Console.
    }
  }
}