rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VOID WEAR - Master Administrative Security Rules v4.0
     * Primary Administrator: voidwear26@gmail.com
     * System: Absolute Authority Override
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() == "voidwear26@gmail.com"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- MASTER OVERRIDE ---
    // Grants absolute authority to the Master Admin account across the entire database.
    // This allows collection group queries and global list operations.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- STANDARD USER RULES ---
    // Rules for non-admin entities navigating the void.

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);

      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /app_config/{configId} {
      allow get, list: if true;
    }

    match /products/{productId} {
      allow get, list: if true;
    }
    
    // Deployment Comment: Triggering rules sync for Master Authority v4.0
  }
}