
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VOID WEAR SECURITY RULES
     * 
     * MASTER AUTHORITY: voidwear26@gmail.com
     * VERSION: 12.6 - ROBUST OWNER ACCESS
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.keys().contains('email') && 
             request.auth.token.email.lower() == 'voidwear26@gmail.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /app_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /stories/{storyId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /users/{userId} {
      // Allow any signed-in user to manage their own dossier
      allow get, create, update: if isOwner(userId);
      
      // Allow admin to audit all users
      allow list, delete: if isAdmin();
      allow get, update: if isAdmin();

      match /carts/{cartId} {
        allow get, list, create, update, delete: if isOwner(userId) || isAdmin();

        match /items/{itemId} {
          allow get, list, create, update, delete: if isOwner(userId) || isAdmin();
        }
      }

      match /orders/{orderId} {
        allow get, list, create: if isOwner(userId);
        allow get, list, update, delete: if isAdmin();
      }

      match /wishlist/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    /**
     * @description Collection Group rules for Global Mission Audits (Admin only).
     */
    match /{path=**}/orders/{orderId} {
      allow read: if isAdmin();
    }

    match /{path=**}/items/{itemId} {
      allow read: if isAdmin();
    }
  }
}
