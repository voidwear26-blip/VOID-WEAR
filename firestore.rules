rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VOID WEAR - Master Administrative Security Rules v9.0
     * Primary Administrator: voidwear26@gmail.com
     * Absolute Authority Override (Full Root + Collection Group Support)
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "voidwear26@gmail.com"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- MASTER OVERRIDE ---
    // Grants absolute access to all paths for the Master Administrator.
    // This recursive wildcard at root level handles all collections, subcollections, and collection group queries.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- COLLECTION GROUP OVERRIDES ---
    // Specifically allow admin to query 'orders' and 'items' across the entire database.
    // Note: Collection group rules must match the last segment of the path.
    match /{path=**}/orders/{orderId} {
      allow read, write: if isAdmin();
    }
    
    match /{path=**}/items/{itemId} {
      allow read, write: if isAdmin();
    }

    // --- STANDARD ENTITY RULES ---
    match /users/{userId} {
      allow get, create, update: if isOwner(userId);

      match /orders/{orderId} {
        allow read, write: if isOwner(userId);
      }
      
      match /carts/{cartId}/{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
      
      match /wishlist/{wishId} {
        allow read, write: if isOwner(userId);
      }
      
      match /addresses/{addrId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /app_config/{configId} {
      allow get, list: if true;
    }

    match /products/{productId} {
      allow get, list: if true;
    }
    
    // Deployment Comment: Initializing Master Authority v9.0 - Absolute Root & Collection Group Clearance
  }
}