rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VOID WEAR SECURITY RULES v30.0
     * MASTER AUTHORITY: voidwear26@gmail.com (A9vsqn10oddfmouKiKjWpTcFqZB2)
     * UNIVERSAL OVERRIDE FOR GLOBAL TRANSMISSION AUDITS
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'A9vsqn10oddfmouKiKjWpTcFqZB2' ||
        (request.auth.token.email != null && request.auth.token.email.lower() == 'voidwear26@gmail.com')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Universal Master Authority ---
    // This top-level match ensures Admin identities have absolute oversight.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- Collection Group Rule for Orders ---
    // Optimized for the new composite index: orderDate (DESC), order_ID (ASC)
    match /{path=**}/orders/{orderId} {
      // Master Audit: Absolute visibility at root for global queries
      allow list: if isAdmin();
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      // Operator: Restricted to their own dossier for list operations
      allow list: if isSignedIn() && (request.query.limit <= 100); 
      
      // Create/Update Logic
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // --- Standard Collection Access ---

    match /app_config/{configId} {
      allow read: if true;
    }

    match /stories/{storyId} {
      allow read: if true;
    }

    match /products/{productId} {
      allow read: if true;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid);
    }

    match /users/{userId} {
      allow get, list, create, update: if isOwner(userId) || isAdmin();
      
      match /carts/{cartId} {
        allow read, write: if isOwner(userId) || isAdmin();
        match /items/{itemId} {
          allow read, write: if isOwner(userId) || isAdmin();
        }
      }

      match /wishlist/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
  }
}