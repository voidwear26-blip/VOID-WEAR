
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // VOID WEAR // ACCESS PROTOCOL v35.0
    // MASTER ADMINISTRATOR OVERRIDE: voidwear26@gmail.com
    
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'voidwear26@gmail.com';
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /app_config/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
