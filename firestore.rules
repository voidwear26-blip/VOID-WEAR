rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VOID WEAR - Master Administrative Security Rules v5.0
     * Primary Administrator: voidwear26@gmail.com
     * System: Absolute Authority Override (Root-Level)
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "voidwear26@gmail.com"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- MASTER OVERRIDE ---
    // Grants absolute authority to the Master Admin account for ALL paths and Collection Groups.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- STANDARD USER RULES ---
    // Standard access rules for non-admin entities.

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);

      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /app_config/{configId} {
      allow get, list: if true;
    }

    match /products/{productId} {
      allow get, list: if true;
    }
    
    // Deployment Comment: Synchronizing Master Authority v5.0 for Root Access
  }
}