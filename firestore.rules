
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // VOID WEAR // GLOBAL ACCESS OVERRIDE v25.0
    // Granting unrestricted read/write access to all collections to ensure 
    // administrative modules (Add/Delete/Update) function without permission blocks.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
