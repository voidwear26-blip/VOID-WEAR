rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'A9vsqn10oddfmouKiKjWpTcFqZB2' ||
        (request.auth.token.email != null &&
         request.auth.token.email.lower() == 'voidwear26@gmail.com')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- PRODUCTS (public) ---
    match /products/{productId} {
      allow read, get, list: if true;
    }

    // --- REVIEWS (public read, restricted write) ---
    match /reviews/{reviewId} {
      allow read, get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // ✅ CollectionGroup support for reviews
    match /{path=**}/reviews/{reviewId} {
      allow read, get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // --- CONTACTS ---
    match /contacts/{contactId} {
      allow create: if true;
      allow read: if isAdmin();
    }

    // --- CONFIG ---
    match /app_config/{configId} {
      allow read: if true;
    }

    // --- STORIES ---
    match /stories/{storyId} {
      allow read, list: if true;
    }

    // --- USERS ---
    match /users/{userId} {
      allow get, list, create, update: if isOwner(userId) || isAdmin();

      match /carts/{cartId} {
        allow read, write: if isOwner(userId) || isAdmin();

        match /items/{itemId} {
          allow read, write: if isOwner(userId) || isAdmin();
        }
      }

      match /wishlist/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /orders/{orderId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
      }
    }

    // --- COLLECTION GROUP: ORDERS ---
    match /{path=**}/orders/{orderId} {
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 100);
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // --- ADMIN CATCH-ALL ---
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}