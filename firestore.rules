rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VOID WEAR - Security Rules Architecture
     *
     * Core Philosophy: 
     * This ruleset enforces a strict user-ownership model where private data is nested under user-specific paths.
     * It utilizes Database-Backed Access Control (DBAC) for administrative privileges and focuses on
     * authorization independence through denormalization.
     *
     * Data Structure:
     * - User-owned data (Profiles, Addresses, Carts, Orders) is nested under /users/{userId}.
     * - Public catalog data (Products, Variants) is stored at the top level for global read access.
     * - Administrative roles are managed in a dedicated /app_roles/admin collection.
     *
     * Key Security Decisions:
     * - Prototyping Mode: Schema validation is ignored for general fields to allow rapid iteration.
     * - Relational Integrity: Essential fields (like userId) are validated on create and update.
     * - Ownership: All user-owned data requires the authenticated UID to match the path userId.
     * - Admin Access: Write access to the product catalog is restricted to users present in the admin roles collection.
     *
     * Denormalization for Authorization:
     * To ensure high-performance and atomic security checks, userId is expected to be present both in 
     * the document path and as a field within nested documents. This avoids expensive get() calls.
     */

    // --- HELPER FUNCTIONS ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is an owner and the document exists (for updates/deletes). */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /** @description Checks if the authenticated user has administrative privileges via DBAC. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/app_roles/admin/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for individual user profile documents.
     * @path /users/{userId}
     * @allow (create) request.auth.uid == userId
     * @deny (read) request.auth.uid != userId
     * @principle Self-creation and strict ownership for user profiles.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for shipping and billing addresses owned by a user.
       * @path /users/{userId}/addresses/{addressId}
       * @allow (list) request.auth.uid == userId
       * @deny (create) request.resource.data.userId != userId
       * @principle Enforces path-based ownership and relational integrity for user addresses.
       */
      match /addresses/{addressId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for the user's active shopping cart.
       * @path /users/{userId}/carts/active_cart
       * @allow (update) request.auth.uid == userId
       * @deny (get) request.auth.uid != userId
       * @principle Restricts cart management to the account owner.
       */
      match /carts/active_cart {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Rules for items within a user's active cart.
         * @path /users/{userId}/carts/active_cart/items/{itemId}
         * @allow (create) request.auth.uid == userId
         * @deny (list) request.auth.uid != userId
         * @principle Secures nested cart items using parent ownership context.
         */
        match /items/{itemId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId);
          allow update: if isExistingOwner(userId);
          allow delete: if isExistingOwner(userId);
        }
      }

      /**
       * @description Rules for historical and pending user orders.
       * @path /users/{userId}/orders/{orderId}
       * @allow (get) request.auth.uid == userId
       * @deny (update) request.resource.data.userId != resource.data.userId
       * @principle Ensures users can only access their own orders; preserves relational links.
       */
      match /orders/{orderId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Rules for specific items purchased in an order.
         * @path /users/{userId}/orders/{orderId}/items/{itemId}
         * @allow (list) request.auth.uid == userId
         * @deny (delete) request.auth.uid != userId
         * @principle Protects order line items based on user ownership.
         */
        match /items/{itemId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId);
          allow update: if isExistingOwner(userId);
          allow delete: if isExistingOwner(userId);
        }
      }
    }

    /**
     * @description Rules for the public product catalog.
     * @path /products/{productId}
     * @allow (get) true
     * @deny (create) !isAdmin()
     * @principle Public read access for marketing; write access restricted to administrators.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();

      /**
       * @description Rules for specific variations of a product (size, color, etc).
       * @path /products/{productId}/variants/{variantId}
       * @allow (list) true
       * @deny (update) !isAdmin()
       * @principle Public availability of variant data with administrative write control.
       */
      match /variants/{variantId} {
        allow get, list: if true;
        allow create, update, delete: if isAdmin();
      }
    }

    /**
     * @description Rules for the administrative role mapping collection.
     * @path /app_roles/admin/{adminId}
     * @allow (get) isAdmin()
     * @deny (write) true
     * @principle System-managed collection for DBAC; not modifiable by standard users.
     */
    match /app_roles/admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false; // Role assignment typically handled by a secure backend/Cloud Function
    }
  }
}