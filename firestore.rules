rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VOID WEAR SECURITY RULES
     * MASTER AUTHORITY: voidwear26@gmail.com
     * VERSION: 17.0 - UNIVERSAL ROOT OVERRIDE ACTIVE
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'voidwear26@gmail.com' || 
        request.auth.uid == 'A9vsqn10oddfmouKiKjWpTcFqZB2'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Universal Master Authority ---
    // Grants absolute authority over every document and collection group in the architecture.
    // Prioritized to ensure Command Center (Revenue Audits, System Archives) functionality.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- Collection Group Audit Protocol ---
    // Specifically enables global audits for nested collections required by the dashboard.
    match /{path=**}/orders/{orderId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /{path=**}/carts/{cartId} {
      allow read, write: if isAdmin();
    }

    // --- Collection Specific Rules (For Non-Admin Operators) ---

    match /app_config/{configId} {
      allow read: if true;
    }

    match /stories/{storyId} {
      allow read: if true;
    }

    match /products/{productId} {
      allow read: if true;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid);
    }

    match /users/{userId} {
      allow get, create, update: if isOwner(userId) || isAdmin();
      
      match /carts/{cartId} {
        allow read, write: if isOwner(userId) || isAdmin();
        match /items/{itemId} {
          allow read, write: if isOwner(userId) || isAdmin();
        }
      }

      match /orders/{orderId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /wishlist/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
  }
}