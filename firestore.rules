
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // MASTER AUTHORITY PROTOCOL
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'voidwear26@gmail.com';
    }

    // 1. ABSOLUTE ADMINISTRATIVE OVERRIDE
    // This grants full access to all paths for the admin entity.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // 2. PUBLIC PRODUCT CATALOG
    match /products {
      allow list: if true;
    }
    match /products/{productId} {
      allow read: if true;
    }

    // 3. GLOBAL APP CONFIGURATION
    match /app_config/{configId} {
      allow read: if true;
    }

    // 4. USER SPECIFIC DATA
    // Allows users to manage their own profile, orders, and cart.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 5. GLOBAL SEARCH (For Admin Logistics)
    match /{path=**}/orders/{orderId} {
      allow read: if isAdmin();
    }
  }
}
