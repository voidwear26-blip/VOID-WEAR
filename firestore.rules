
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. MASTER ADMINISTRATIVE OVERRIDE
    // Prioritizes the primary administrator for all system nodes.
    match /{document=**} {
      allow read, write: if request.auth != null && 
                          request.auth.token.email != null && 
                          request.auth.token.email.lower() == 'voidwear26@gmail.com';
    }

    // 2. UNRESTRICTED PRODUCT CATALOG
    // Allows public access to products and config to unblock admin prototyping.
    match /products/{document=**} {
      allow read, write: if true;
    }
    match /app_config/{document=**} {
      allow read, write: if true;
    }

    // 3. USER SPECIFIC NODES
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
