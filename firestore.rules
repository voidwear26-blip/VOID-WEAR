rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VOID WEAR - Security Rules Architecture v1.5
     * Optimized for Master Administrative Command and Global Logistics.
     * Deployment Trigger: Root-level Administrative Email Authorization Sync.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Master Admin Authorization.
     * Checks for the hardcoded master email.
     */
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "voidwear26@gmail.com";
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- MASTER OVERRIDE ---
    // Universal access for the Master Administrator.
    // This recursive wildcard match handles both single documents and collection group queries.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- COLLECTION RULES ---

    // Users & Profiles
    match /users/{userId} {
      // Admins can list all entities; users can only see themselves.
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isExistingOwner(userId) || isAdmin()) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId) || isAdmin();

      // Sub-collections inherit owner/admin access.
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /carts/active_cart {
        allow read, write: if isOwner(userId) || isAdmin();
        match /items/{itemId} {
          allow read, write: if isOwner(userId) || isAdmin();
        }
      }

      match /orders/{orderId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /wishlist/{wishlistId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Global App Configuration
    match /app_config/{configId} {
      allow get, list: if true; // Publicly readable for branding.
      allow write: if isAdmin();
    }

    // Product Catalog
    match /products/{productId} {
      allow get, list: if true; // Publicly readable.
      allow create, update, delete: if isAdmin();

      match /variants/{variantId} {
        allow get, list: if true;
        allow create, update, delete: if isAdmin();
      }
    }

    // System Roles (Read-only for identification)
    match /app_roles/admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if false; // Only manageable via Firebase Console.
    }
  }
}