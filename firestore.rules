
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VOID WEAR SECURITY RULES
     * 
     * MASTER AUTHORITY: voidwear26@gmail.com
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email.lower() == 'voidwear26@gmail.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Public application configuration.
     * Denied auth request triggered this update. Fixed to allow public read.
     */
    match /app_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Public brand narratives.
     */
    match /stories/{storyId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Public product catalog.
     */
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Product feedback audit logs.
     */
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    /**
     * @description Rules for the User profile and nested collections.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isExistingOwner(userId) || isAdmin());
      allow delete: if isAdmin();

      match /carts/{cartId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId) || isAdmin();
        allow delete: if isExistingOwner(userId) || isAdmin();

        match /cartItems/{cartItemId} {
          allow get, list: if isOwner(userId) || isAdmin();
          allow create: if isOwner(userId);
          allow update, delete: if isExistingOwner(userId) || isAdmin();
        }
      }

      match /orders/{orderId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update: if isAdmin();
        allow delete: if isAdmin();

        match /orderItems/{orderItemId} {
          allow get, list: if isOwner(userId) || isAdmin();
          allow create: if isOwner(userId);
          allow update, delete: if isAdmin();
        }
      }

      match /wishlist/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    /**
     * @description Collection Group rules for Global Order Monitoring (Admin only).
     */
    match /{path=**}/orders/{orderId} {
      allow read: if isAdmin();
    }
  }
}
