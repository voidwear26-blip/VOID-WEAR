rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VOID WEAR SECURITY RULES v25.0
     * MASTER AUTHORITY: voidwear26@gmail.com (A9vsqn10oddfmouKiKjWpTcFqZB2)
     * PRIORITY AUTHORIZATION FOR GLOBAL AUDITS & DUAL-ID VERIFICATION
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'A9vsqn10oddfmouKiKjWpTcFqZB2' ||
        (request.auth.token.email != null && request.auth.token.email.lower() == 'voidwear26@gmail.com')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Universal Master Authority ---
    // This rule is the primary override for all administrative actions.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- Specific Collection Group Rule for Orders ---
    // Critical for the Command Center's global 'list' operations.
    match /{path=**}/orders/{orderId} {
      // Admin: Absolute oversight without document-level constraints
      allow list, get, update, delete: if isAdmin();
      
      // Operator: Restricted to their own dossier. 
      // Query MUST include filter: .where('userId', '==', user.uid)
      allow list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow get: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // --- Standard Collection Access ---

    match /app_config/{configId} {
      allow read: if true;
    }

    match /stories/{storyId} {
      allow read: if true;
    }

    match /products/{productId} {
      allow read: if true;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid);
    }

    match /users/{userId} {
      // Granting full access to owners for profile management
      allow get, list, create, update: if isOwner(userId) || isAdmin();
      
      match /carts/{cartId} {
        allow read, write: if isOwner(userId) || isAdmin();
        match /items/{itemId} {
          allow read, write: if isOwner(userId) || isAdmin();
        }
      }

      match /orders/{orderId} {
        // Standard user access to their subcollection
        allow list, get: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update, delete: if isAdmin();
      }

      match /wishlist/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
  }
}