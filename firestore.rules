
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // MASTER AUTHORITY PROTOCOL
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'voidwear26@gmail.com';
    }

    // User Collection Listing (Needed for Admin Dashboard)
    match /users {
      allow list: if isAdmin();
    }

    // Product Collection Listing
    match /products {
      allow list: if true;
    }

    // Product Catalog Documents
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Data & Orders
    match /users/{userId}/{document=**} {
      allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
    }

    // App Configuration
    match /app_config/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Global Search & Listing (Needed for Transmissions)
    match /{path=**}/orders/{orderId} {
      allow read: if isAdmin();
    }

    // Root Level Fallback for Administrative Control
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
