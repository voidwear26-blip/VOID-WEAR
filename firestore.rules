
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // MASTER AUTHORITY PROTOCOL v15.0
    // Explicitly grants absolute authority to the master administrator account.
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email != null && 
             request.auth.token.email.lower() == 'voidwear26@gmail.com';
    }

    // 1. ABSOLUTE ADMINISTRATIVE OVERRIDE
    // This rule takes precedence and allows any operation if identified as Admin.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // 2. PUBLIC PRODUCT CATALOG
    // Allows anyone to browse and view product modules.
    match /products {
      allow list: if true;
    }
    match /products/{productId} {
      allow read: if true;
    }

    // 3. GLOBAL APP CONFIGURATION
    match /app_config/{configId} {
      allow read: if true;
    }

    // 4. USER SPECIFIC DATA
    // Allows entities to manage their own orders, addresses, and wishlist.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 5. GLOBAL SEARCH & LOGISTICS
    // Explicitly permits cross-collection group queries for admin logistics.
    match /{path=**}/orders/{orderId} {
      allow read: if isAdmin();
    }
    
    match /users {
      allow list: if isAdmin();
    }
  }
}
