
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. UNRESTRICTED ACCESS FOR PROTOTYPING
    // Directly allowing all operations on core collections as requested.
    match /products/{document=**} {
      allow read, write: if true;
    }
    match /app_config/{document=**} {
      allow read, write: if true;
    }

    // 2. USER SPECIFIC NODES
    match /users/{userId}/{document=**} {
      allow read, write: if true;
    }

    // 3. MASTER OVERRIDE FOR OTHER NODES
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
