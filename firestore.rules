
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VOID WEAR SECURITY RULES v24.0
     * MASTER AUTHORITY: voidwear26@gmail.com (A9vsqn10oddfmouKiKjWpTcFqZB2)
     * BULLETPROOF AUTHORIZATION FOR GLOBAL AUDITS
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'A9vsqn10oddfmouKiKjWpTcFqZB2' ||
        (request.auth.token.email != null && request.auth.token.email.lower() == 'voidwear26@gmail.com')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Universal Master Authority ---
    // Grants absolute authority to the Master Administrator for all documents.
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- Explicit Collection Group Audit Rule ---
    // Critical for global order tracking and revenue aggregation in Command Center.
    // We split the rules to ensure that broad 'list' operations (like collectionGroup) 
    // are authorized statically for admins without triggering document-relative checks.
    match /{path=**}/orders/{orderId} {
      // Admin access: Absolute oversight
      allow list, read, update, delete: if isAdmin();
      
      // Operator access: Restricted to own dossier
      // Requires filter by userId in queries for 'list' to pass for non-admins
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && request.query.limit <= 100 && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // --- Standard Collection Access for Operators ---

    match /app_config/{configId} {
      allow read: if true;
    }

    match /stories/{storyId} {
      allow read: if true;
    }

    match /products/{productId} {
      allow read: if true;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid);
    }

    match /users/{userId} {
      // Granting full access to owners for dossier management
      allow get, list, create, update: if isOwner(userId) || isAdmin();
      
      match /carts/{cartId} {
        allow read, write: if isOwner(userId) || isAdmin();
        match /items/{itemId} {
          allow read, write: if isOwner(userId) || isAdmin();
        }
      }

      match /orders/{orderId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update, delete: if isAdmin();
      }

      match /wishlist/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
  }
}
